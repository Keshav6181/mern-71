<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background-color: #27aab9;
      }
      .container {
        width: 800px;
        height: 500px;
        margin: auto;
        margin-top: 100px;
        border: 5px solid black;

        display: grid;
        grid-template-columns: repeat(9, 1fr);
        grid-template-rows: repeat(8, 1fr);
      }
      .item {
        border: 5px solid rgb(0, 0, 0);
      }
      .item1 {
        grid-column: 1/3;
        grid-row: 1/5;
        background-color: #c51212;
      }
      .item2 {
        grid-column: 3/6;
        grid-row: 1/3;
        background-color: #1292c5;
      }
      .item3 {
        grid-column: 6/10;
        grid-row: 1/3;
        background-color: #12c524;
      }
      .item4 {
        grid-column: 3/5;
        grid-row: 3/6;
        background-color: #c58f12;
      }
      .item5 {
        grid-column: 5/8;
        grid-row: 3/6;
        background-color: #edeced;
      }
      .item6 {
        grid-column: 8/10;
        grid-row: 3/9;
        background-color: #c51212;
      }
      .item7 {
        grid-column: 1/3;
        grid-row: 5/9;
        background-color: #eee6c5;
      }
      .item8 {
        grid-column: 3/6;
        grid-row: 6/9;
        background-color: #c51212;
      }
      .item9 {
        grid-column: 6/8;
        grid-row: 6/9;
        background-color: #12a2c5;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="item item1"></div>
      <div class="item item2"></div>
      <div class="item item3"></div>
      <div class="item item4"></div>
      <div class="item item5"></div>
      <div class="item item6"></div>
      <div class="item item7"></div>
      <div class="item item8"></div>
      <div class="item item9"></div>
    </div>
  </body>
</html>
