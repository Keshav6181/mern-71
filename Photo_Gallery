<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Simple Photo Gallery</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        background-color: #21eac9;
        padding: 24px;
      }

      .gallery {
        max-width: 1100px;
        margin: 0 auto;
      }

      .gallery h1 {
        font-size: 1.8rem;
        margin-bottom: 18px;
        color: #202124;
      }

      .photo-grid {
        column-count: 3;
        column-gap: 14px;
      }

      .photo-item {
        margin-bottom: 14px;
        overflow: hidden;
        border-radius: 10px;
      }

      .photo-item img {
        width: 100%;
        display: block;
        border-radius: 10px;
      }

      @media (max-width: 800px) {
        .photo-grid {
          column-count: 2;
        }
      }

      @media (max-width: 500px) {
        .photo-grid {
          column-count: 1;
        }
      }
    </style>
  </head>
  <body>
    <div class="gallery">
      <h1>Photos</h1>
      <div class="photo-grid">
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=800&q=80"
            alt="Mountain"
          />
        </div>
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1493246507139-91e8fad9978e?auto=format&fit=crop&w=800&q=80"
            alt="Forest"
          />
        </div>
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=800&q=80"
            alt="Lake"
          />
        </div>
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=800&q=80"
            alt="Ocean"
          />
        </div>
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=80"
            alt="Landscape"
          />
        </div>
        <div class="photo-item">
          <img
            src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=800&q=80"
            alt="Beach"
          />
        </div>
      </div>
      <div class="footer">
        <p>Simple Photo Gallery.</p>
      </div>
    </div>
  </body>
</html>
